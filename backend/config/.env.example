# 识海 (Consciousness Sea) 配置

# 数据库路径
CONSCIOUSNESS_SEA_DB_PATH=data/consciousness_sea.db
CONSCIOUSNESS_SEA_DATA_DIR=data

# API 服务
CONSCIOUSNESS_SEA_API_HOST=127.0.0.1
CONSCIOUSNESS_SEA_API_PORT=8111

# API 认证
CONSCIOUSNESS_SEA_API_KEY=
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRATION_HOURS=24

# CORS 白名单（逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# HTTPS（留空则使用 HTTP）
SSL_CERTFILE=
SSL_KEYFILE=

# 专家模型
CONSCIOUSNESS_SEA_EXPERT_MODEL_PATH=
CONSCIOUSNESS_SEA_EXPERT_BACKEND=ollama
CONSCIOUSNESS_SEA_OLLAMA_BASE_URL=http://localhost:11434
CONSCIOUSNESS_SEA_OLLAMA_MODEL=qwen2.5:7b
